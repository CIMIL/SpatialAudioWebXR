---
import BaselineSlide from "../components/BaselineSlide.astro";
import Sphere from "../components/Sphere.astro";
import Player from "../components/player/Player.astro";
import ExperienceLayout from "../layouts/ExperienceLayout.astro";
---

<ExperienceLayout title="Panner Node">
  <Fragment slot="head">
    <script src="/e1.js" type="module" is:inline></script>
  </Fragment>
  <a-scene background="color: #242424">
    <a-assets>
      <a-entity bind-for="for: item; in: audioSources; key: id">
        <template>
          <audio
            id="{{id}}"
            crossorigin="anonymous"
            preload="auto"
            src="/sound.wav"></audio>
        </template>
      </a-entity>
    </a-assets>

    <BaselineSlide />
    <Sphere>
      <a-entity bind-for="for: item; in: speakers; key: id">
        <template>
          <a-sound
            player
            id="{{id}}"
            src="{{audioSrc}}"
            position="{{position}}"
            volume="10"
          >
            <a-box
              id="{{id}}-box"
              look-at="#player"
              scale="0.2 0.2 0.2"
              data-clickable
            >
              <a-text
                value="{{id}}"
                align="center"
                position="0 0 1.25"
                scale="0.5 0.5 0.5"
                color="blue"></a-text>
            </a-box>
          </a-sound>
        </template>
      </a-entity>
    </Sphere>

    <Player />
  </a-scene>
</ExperienceLayout>
