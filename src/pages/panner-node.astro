---
import ExperienceLayout from "../layouts/ExperienceLayout.astro";
---

<ExperienceLayout title="Panner Node">
  <Fragment slot="head">
    <script src="/e1.js" type="module" is:inline></script>
  </Fragment>
  <a-scene background="color: #242424">
    <a-assets>
      <a-entity bind-for="for: item; in: audioSources; key: id">
        <template>
          <audio
            id="{{id}}"
            crossorigin="anonymous"
            preload="auto"
            src="/sound.wav"></audio>
        </template>
      </a-entity>
    </a-assets>

    <!-- spawn a vertical plane at 2 meters from the player -->
    <a-plane
      id="baseline-slide"
      position="0 0 -1.5"
      rotation="0 0 0"
      width="1"
      height="0.5"
      color="#fea3aa"
      data-clickable
      visible="false"
    >
      <a-text
        id="baseline-slide-text"
        align="center"
        value="Look here for 30 seconds"
        width="1"
      >
      </a-text>
    </a-plane>

    <a-sphere
      bind="radius: sphereRadius"
      segments-width="36"
      segments-height="18"
      wireframe="true"
    >
      <a-entity bind-for="for: item; in: speakers; key: id">
        <template>
          <a-sound
            player
            id="{{id}}"
            src="{{audioSrc}}"
            position="{{position}}"
            volume="10"
          >
            <a-box
              id="{{id}}-box"
              look-at="#player"
              scale="0.2 0.2 0.2"
              data-clickable
            >
              <a-text
                value="{{id}}"
                align="center"
                position="0 0 1.25"
                scale="0.5 0.5 0.5"
                color="blue"></a-text>
            </a-box>
          </a-sound>
        </template>
      </a-entity>
    </a-sphere>

    <a-entity id="player">
      <!-- camera -->
      <a-entity
        id="camera"
        camera
        position="0 0 0"
        wasd-controls
        look-controls
        cursor="rayOrigin: mouse"
      >
        <a-text
          id="message-box"
          bind="value: messageBox"
          color="white"
          position="-0.7 -0.7 -2"
          scale="0.3 0.3 0.3 "
          align="center"></a-text>
        <a-text
          value="Score"
          color="white"
          position="0.7 -0.6 -2"
          scale="0.3 0.3 0.3 "
          align="center"></a-text>
        <a-text
          id="score-box"
          bind="value: score"
          color="white"
          position="0.7 -0.7 -2"
          scale="0.3 0.3 0.3 "
          align="center"></a-text>
      </a-entity>

      <!-- hand controls -->
      <a-entity id="left-hand" oculus-touch-controls="hand: left">
        <!-- show a plane oriented as the controller -->
        <a-plane
          id="menu"
          position="0 0.04 -0.15"
          rotation="-45 0 0"
          color="#fea3aa"
          width="0.1"
          height="0.1"
        >
          <!-- box with text back -->
          <a-box
            position="0 0 0.01"
            color="black"
            width="0.1"
            height="0.1"
            depth="0.01"
            back-button
            data-clickable
          >
            <a-text
              value="Back"
              align="center"
              position="0 0 0.01"
              scale="0.1 0.1 0.1"
              color="white"></a-text>
          </a-box>
          <a-box
            position="0 0.15 0.01"
            color="black"
            width="0.1"
            height="0.1"
            depth="0.01"
            start-button
            data-clickable
          >
            <a-text
              value="Start"
              align="center"
              position="0 0 0.01"
              scale="0.1 0.1 0.1"
              color="white"></a-text>
          </a-box>
        </a-plane>
      </a-entity>
      <a-entity
        id="right-hand"
        oculus-touch-controls="hand: right"
        laser-controls="hand: right; model: true"
        raycaster="objects: [data-clickable]"></a-entity>
    </a-entity>
  </a-scene>
</ExperienceLayout>
