<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <style>
    /* styles.css */
    body {
      font-family: Arial, sans-serif;
      background-color: #121212;
      color: #E0E0E0;
      margin: 0;
      padding: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .container {
      background-color: #1E1E1E;
      padding: 20px;
      border-radius: 8px;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.5);
      max-width: 600px;
      width: 100%;
      text-align: center;
    }

    h1 {
      color: #E1E1E1;
      margin-bottom: 20px;
    }

    #error {
      color: #f44336;
      margin-bottom: 20px;
    }

    pre {
      background-color: #2E2E2E;
      color: #E0E0E0;
      padding: 10px;
      border-radius: 4px;
      text-align: left;
      overflow-x: auto;
      max-height: 300px;
    }
  </style>
  <script src="../utils/fileupload.js"></script>
</head>
<body>
  <div class="container">
    <h1>Uploading Results...</h1>
    <p id="error" class="error"></p>
    <pre id="data"></pre>
  </div>
</body>
</html>
