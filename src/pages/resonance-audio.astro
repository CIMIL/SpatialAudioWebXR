---
import BaselineSlide from "../components/BaselineSlide.astro";
import Sphere from "../components/Sphere.astro";
import Player from "../components/player/Player.astro";
import ExperienceLayout from "../layouts/ExperienceLayout.astro";
import Scene from "../components/Scene.astro";

import { distributeSpeakers } from "../utils/distribute-speakers";
import { SPEAKER_RADIUS } from "../utils/constants";
import AudioSrc from "../components/AudioSrc.astro";

const speakerPositions = distributeSpeakers(SPEAKER_RADIUS);

const audioSources = Array.from({ length: 64 }, (_, i) => ({
  id: `src-${i}`,
}));

const speakers = Array.from({ length: 64 }, (_, i) => ({
  id: `speaker-${i}`,
  audioSrc: `#src-${i}`,
  position: `${speakerPositions[i].x} ${speakerPositions[i].y} ${speakerPositions[i].z}`,
}));
---

<ExperienceLayout title="Panner Node">
  <Fragment slot="head">
    <script
      src="https://cdn.jsdelivr.net/npm/aframe-resonance-audio-component@1.1.0/dist/aframe-resonance-audio-component.min.js"
      is:inline></script>
    <script src="../utils/e2.js"></script>
  </Fragment>
  <Scene>
    <a-assets>
      {audioSources.map((source) => <AudioSrc id={source.id} />)}
    </a-assets>

    <BaselineSlide />

    <Sphere>
      <a-resonance-audio-room
        width="20"
        height="20"
        depth="20"
        ambisonic-order="3"
        speed-of-sound="343"
        left="acoustic-ceiling-tiles"
        right="acoustic-ceiling-tiles"
        front="acoustic-ceiling-tiles"
        back="acoustic-ceiling-tiles"
        down="acoustic-ceiling-tiles"
        up="acoustic-ceiling-tiles"
      >
        {
          speakers.map((speaker) => (
            <a-entity
              key={speaker.id}
              id={speaker.id}
              position={speaker.position}
              resonance-audio-src={`src: ${speaker.audioSrc}; autoplay: false; loop: false; gain: 10`}
              player
            >
              <a-box
                id={`${speaker.id}-box`}
                look-at="#player"
                data-clickable
                scale="0.2 0.2 0.2"
              >
                <a-text
                  value={speaker.id}
                  align="center"
                  position="0 0.200 1.25"
                  scale="0.5 0.5 0.5"
                  color="blue"
                />
              </a-box>
            </a-entity>
          ))
        }
      </a-resonance-audio-room>
    </Sphere>

    <Player />
  </Scene>
</ExperienceLayout>
