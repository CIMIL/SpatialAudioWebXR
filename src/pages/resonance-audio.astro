---
import BaselineSlide from "../components/BaselineSlide.astro";
import Sphere from "../components/Sphere.astro";
import Player from "../components/player/Player.astro";
import ExperienceLayout from "../layouts/ExperienceLayout.astro";
---

<ExperienceLayout title="Panner Node">
  <Fragment slot="head">
    <script
      src="https://cdn.jsdelivr.net/npm/aframe-resonance-audio-component@1.1.0/dist/aframe-resonance-audio-component.min.js"
      is:inline></script>
    <script src="/e2.js" type="module" is:inline></script>
  </Fragment>
  <a-scene background="color: #242424" start>
    <a-assets>
      <a-entity bind-for="for: item; in: audioSources; key: id">
        <template>
          <audio
            id="{{id}}"
            crossorigin="anonymous"
            preload="auto"
            src="/sound.wav"
            loop="false"></audio>
        </template>
      </a-entity>
    </a-assets>

    <BaselineSlide />

    <Sphere>
      <a-resonance-audio-room
        width="20"
        height="20"
        depth="20"
        ambisonic-order="3"
        speed-of-sound="343"
        left="acoustic-ceiling-tiles"
        right="acoustic-ceiling-tiles"
        front="acoustic-ceiling-tiles"
        back="acoustic-ceiling-tiles"
        down="acoustic-ceiling-tiles"
        up="acoustic-ceiling-tiles"
      >
        <a-entity wait-for-room bind-for="for: item; in: speakers; key: id">
          <template>
            <a-entity
              player
              id="{{id}}"
              position="{{position}}"
              resonance-audio-src="src: {{audioSrc}}; autoplay: false; loop: false; gain: 10"
            >
              <a-box
                id="{{id}}-box"
                look-at="#player"
                data-clickable
                scale="0.2 0.2 0.2"
              >
                <a-text
                  value="{{id}}"
                  align="center"
                  position="0 0.200 1.25"
                  scale="0.5 0.5 0.5"
                  color="blue"></a-text>
              </a-box>
            </a-entity>
          </template>
        </a-entity>
      </a-resonance-audio-room>
    </Sphere>

    <Player />
  </a-scene>
</ExperienceLayout>
