---
import Player from "../components/player/Player.astro";
import Portal from "../components/Portal.astro";
import Scene from "../components/Scene.astro";
import DebugButton from "../components/DebugButton.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/aframe-logo-192.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>A-Frame + Vite App</title>
    <script src="https://aframe.io/releases/1.6.0/aframe.min.js" is:inline
    ></script>
    <script
      src="https://unpkg.com/aframe-environment-component@1.3.3/dist/aframe-environment-component.min.js"
      is:inline></script>
    <script
      src="https://unpkg.com/aframe-layout-component@5.3.0/dist/aframe-layout-component.min.js"
      is:inline></script>
    <script
      src="https://unpkg.com/aframe-template-component@3.2.1/dist/aframe-template-component.min.js"
      is:inline></script>
    <script src="../utils/logs.js"></script>
    <script src="../utils/debug.js"></script>
  </head>
  <body>
    <Scene>
      <Fragment slot="assets">
        <img id="panner-node" src="/panner-node.webp" />
        <img id="resonance-audio" src="/resonance-audio.webp" />
        <img id="howler" src="/howler.webp" />
      </Fragment>
      <a-entity position="0 0 -4">
        <Portal text="Panner Node" image="#panner-node" link="/panner-node" position="-2 0 0.3" rotation="0 30 0" />
        <Portal text="Resonance Audio" image="#resonance-audio" link="/resonance-audio" position="0 0 -0.2" rotation="0 0 0" />
        <Portal text="Howler JS" image="#howler" link="/howler" position="2 0 0.3" rotation="0 -30 0" />
        <a-text align="center" position="0 1.8 0" width="8" scale="0.4 0.4 0.4" value="Hi, thanks for trying this demo to experience different way of using spatial audio in web XR. We suggest using 'wolfic browser' however when changing page you are required to re-enter the VR mode due to limitations."></a-text>
        <a-entity position="0 1 0">
          <!-- TODO implement debug button -->
          <!-- <DebugButton /> -->
        </a-entity>
      </a-entity>
      <Player firstPage="true" />
      <a-plane
        width="100"
        height="100" 
        rotation="-90 0 0"
        position="0 -1.60 0"
        color="#1a1a1a"
      ></a-plane>
    </Scene>
  </body>
</html>
