---
import HUD from "./HUD.astro";
import Menu from "./Menu.astro";
const { firstPage } = Astro.props;
---

<Fragment slot="head">
  <script src="../../utils/rotation-header.js"></script>
</Fragment>
<a-entity id="player">
  <!-- camera -->
  <a-camera
    id="camera"
    position="0 0 0"
    wasd-controls
    look-controls
    cursor="rayOrigin: mouse"
    raycaster="objects: [data-watchable], [data-clickable]"
    rotation-header
  >
    <HUD />
    <a-cursor></a-cursor>
  </a-camera>

  <!-- hand controls -->
  <a-entity id="left-hand" oculus-touch-controls="hand: left">
    <!-- show a plane oriented as the controller -->
    <Menu />
  </a-entity>
  <a-entity
    id="right-hand"
    oculus-touch-controls="hand: right"
    laser-controls="hand: right; model: true"
    raycaster="objects: [data-clickable]"></a-entity>
</a-entity>
