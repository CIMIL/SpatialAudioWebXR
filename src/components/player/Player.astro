---
import HUD from "./HUD.astro";
import Menu from "./Menu.astro";
const { firstPage } = Astro.props;
---

<Fragment slot="head">
  <script src="../../utils/rotation-header.js"></script>
</Fragment>
<a-entity id="player">
  <!-- camera -->
  <a-camera
    id="camera"
    position="0 0 0"
    wasd-controls="fly: true; acceleration: 10"
    raycaster="objects: [data-watchable]" 
    cursor="rayOrigin: headset"
    rotation-header
    howler-listener
  >
    <a-cursor></a-cursor>
  </a-camera>

  <!-- hand controls -->
  <a-entity id="left-hand" hand-controls="hand: left">
  </a-entity>
  <a-entity
    id="right-hand"
    hand-controls="hand: right"
    laser-controls="hand: right; model: true"
    raycaster="objects: [data-clickable]"></a-entity>
</a-entity>
