<Fragment slot="head">
  <script src="../../utils/rotation-header.js"></script>
</Fragment>
<a-entity id="player">
  <!-- camera -->
  <a-camera
    id="camera"
    position="0 0 0"
    wasd-controls="fly: true; acceleration: 10"
    raycaster="objects: [data-watchable]" 
    cursor="rayOrigin: headset"
    rotation-header
    howler-listener
  >
  </a-camera>

  <!-- hand controls -->
  <a-entity id="left-hand" laser-controls="hand: left; model: true" raycaster="objects: [data-clickable]"
>
  </a-entity>
  <a-entity
    id="right-hand"
    laser-controls="hand: right; model: true"
    raycaster="objects: [data-clickable]"></a-entity>
</a-entity>
