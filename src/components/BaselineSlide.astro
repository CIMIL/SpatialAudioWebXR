---
import { BASELINE_WAIT_TIME } from "../utils/constants";
---

<a-circle
  id="baseline-slide"
  position="0 0 -1.5"
  rotation="0 0 0"
  radius="0.2"
  color="#fea3aa"
  visible="false"
  data-watchable
>
  <a-text
    id="baseline-slide-text"
    align="center"
    value={BASELINE_WAIT_TIME / 1000}
    width="2"
  >
  </a-text>
</a-circle>
